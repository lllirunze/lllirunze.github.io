---

<div class="terminal" id="terminal-root">
  <div class="terminal-header">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
  </div>

  <div class="terminal-body" id="terminal-body">
    <div class="line">Welcome to Runze's Terminal 👋</div>
    <div class="line">Type 'help' to start</div>

    <div class="input-line">
      <span class="prompt">➜</span>
      <input id="terminal-input" autocomplete="off" />
    </div>
  </div>
</div>

<!-- ⭐ 引入独立CSS -->
<link rel="stylesheet" href="/styles/terminal.css" />

<script>
  import { commands } from "../../scripts/terminalCommands";

  const MAX_LINES = 32;
  const MAX_HISTORY = 100;

  function initTerminal() {
    const body = document.getElementById("terminal-body");
    const input = document.getElementById("terminal-input");

    if (!body || !input) return;

    let history = [];
    let historyIndex = -1;
    const lineUnits = [];
    let totalLineUnits = 0;

    function getLineUnitCount(text) {
      return text.split("\n").length;
    }

    body.querySelectorAll(".line").forEach((el) => {
      const units = getLineUnitCount(el.textContent || "");
      lineUnits.push(units);
      totalLineUnits += units;
    });

    function addLine(text, extraClass = "") {
      const div = document.createElement("div");
      div.className = `line ${extraClass}`.trim();
      div.textContent = text;

      body.insertBefore(div, body.lastElementChild);

      const currentUnits = getLineUnitCount(text);
      lineUnits.push(currentUnits);
      totalLineUnits += currentUnits;

      while (totalLineUnits > MAX_LINES) {
        const firstLine = body.querySelector(".line");
        if (!firstLine) break;
        firstLine.remove();
        totalLineUnits -= lineUnits.shift() || 0;
      }

      body.scrollTop = body.scrollHeight;
    }

    function runCommand(cmd) {
      if (!cmd) return;

      if (cmd === "clear") {
        body.querySelectorAll(".line").forEach(el => el.remove());
        lineUnits.length = 0;
        totalLineUnits = 0;
        return;
      }

      const isKnownCommand = Object.prototype.hasOwnProperty.call(commands, cmd);
      addLine(`$ ${cmd}`, isKnownCommand ? "line-success" : "line-error");

      const output = isKnownCommand ? commands[cmd] : `command not found: ${cmd}`;
      addLine(output);

      history.push(cmd);
      if (history.length > MAX_HISTORY) history.shift();
      historyIndex = -1;
    }

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        runCommand(input.value.trim());
        input.value = "";
      }

      if (e.key === "ArrowUp") {
        if (history.length === 0) return;
        historyIndex = historyIndex < 0 ? history.length - 1 : historyIndex - 1;
        if (historyIndex >= 0) {
          input.value = history[historyIndex];
        }
      }

      if (e.key === "ArrowDown") {
        historyIndex++;
        if (historyIndex < history.length) {
          input.value = history[historyIndex];
        } else {
          input.value = "";
          historyIndex = -1;
        }
      }
    });

    // 点击终端聚焦输入框
    document.getElementById("terminal-root")
      ?.addEventListener("click", () => input.focus());
  }

  // ⭐ Astro 推荐写法：确保 DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTerminal);
  } else {
    initTerminal();
  }
</script>
