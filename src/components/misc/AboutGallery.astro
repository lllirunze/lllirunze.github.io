---
import '@/styles/about-gallery.css'

const frontImages = import.meta.glob('@/assets/images/cards/front/card*.{avif,png,webp,jpg,jpeg}', {
  eager: true,
  import: 'default',
})
const backImages = import.meta.glob('@/assets/images/cards/back/card*.{avif,png,webp,jpg,jpeg}', {
  eager: true,
  import: 'default',
})

const toImageMap = (images) =>
  Object.fromEntries(
    Object.entries(images)
      .map(([path, image]) => {
        const match = path.match(/card(\d+)\.(avif|png|webp|jpe?g)$/)
        if (!match) return null
        return [Number(match[1]), image]
      })
      .filter(Boolean)
  )

const frontImageMap = toImageMap(frontImages)
const backImageMap = toImageMap(backImages)

const galleryCards = Array.from({ length: 6 }, (_, index) => {
  const id = index + 1
  return {
    id,
    title: `Card ${String(id).padStart(2, '0')}`,
    frontImage: frontImageMap[id],
    backImage: backImageMap[id],
  }
})
---

<section class="about-gallery" aria-label="Card gallery">
  <div class="about-gallery-header">
    <div>
      <h2 class="about-gallery-title about-gallery-title--accent">Relics of a Quiet Age</h2>
      <p class="about-gallery-subtitle">Each fragment keeps the warmth of a vanished season.</p>
    </div>
    <div class="about-gallery-controls">
      <button
        type="button"
        class="about-gallery-button"
        data-gallery-prev
        aria-label="Show previous cards"
      >
        ←
      </button>
      <button
        type="button"
        class="about-gallery-button"
        data-gallery-next
        aria-label="Show next cards"
      >
        →
      </button>
    </div>
  </div>

  <div class="about-gallery-viewport" data-gallery-viewport>
    <div class="about-gallery-track" data-gallery-track>
      {galleryCards.map((card) => (
        <article
          class="about-gallery-card"
          data-card-id={card.id}
          aria-label={card.title}
        >
          <button type="button" class="about-gallery-card-inner" aria-label={`Flip ${card.title}`}>
            <div class:list={['about-gallery-face', 'about-gallery-face-front', { 'about-gallery-face-media': !!card.frontImage }]}>
              {card.frontImage ? (
                <img class="about-gallery-image" src={card.frontImage.src} alt={`${card.title} front`} />
              ) : (
                <div class="about-gallery-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class:list={['about-gallery-face', 'about-gallery-face-back', { 'about-gallery-face-media': !!card.backImage }]}>
              {card.backImage ? (
                <img class="about-gallery-image" src={card.backImage.src} alt={`${card.title} back`} />
              ) : (
                <div class="about-gallery-placeholder" aria-hidden="true"></div>
              )}
            </div>
          </button>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import initAboutGallery from '@/scripts/aboutGallery'

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutGallery)
  } else {
    initAboutGallery()
  }
</script>
